{
  "name": "@mastrasystem/pi",
  "version": "0.1.0",
  "description": "Pi extension for controlling Mastra agents from any workspace.",
  "type": "module",
  "license": "UNLICENSED",
  "keywords": [
    "pi-package",
    "pi",
    "mastra",
    "agent",
    "extension"
  ],
  "homepage": "https://github.com/EugeneChan00/mastra-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EugeneChan00/mastra-system.git",
    "directory": "pi"
  },
  "bugs": {
    "url": "https://github.com/EugeneChan00/mastra-system/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js"
    }
  },
  "bin": {
    "mastra-pi": "scripts/launch-pi.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "scripts/launch-pi.mjs",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/extensions/index.js"
    ]
  },
  "scripts": {
    "dev": "node scripts/launch-pi.mjs",
    "smoke:mastra": "npm run build && node scripts/mastra-live-smoke.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "prepack": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "@mariozechner/pi-tui": "^0.70.5",
    "@types/node": "^25.6.0",
    "typebox": "^1.1.24",
    "typescript": "^6.0.3"
  }
}
