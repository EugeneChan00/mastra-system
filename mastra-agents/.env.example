# Daytona Sandbox API
DAYTONA_API_KEY=
DAYTONA_API_SECRET=
MASTRA_DAYTONA_ENDPOINT=https://api.daytona.io

# Database
DATABASE_URL=postgresql://mastra:mastra@localhost:5432/mastra

# Cloudflare Tunnel connector for public webhooks
# Create a remotely managed tunnel in Cloudflare Zero Trust and set its connector token here.
# Configure the tunnel public hostname to route to: http://webhook-server:8080
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_METRICS=0.0.0.0:2000
CLOUDFLARED_LOGLEVEL=info
CLOUDFLARE_WEBHOOK_PUBLIC_URL=https://your-webhook-domain.example.com

# Webhook proxy. This compose stack does not run Mastra; it forwards to the
# Mastra server already running on the Docker host.
WEBHOOK_SERVER_HOST=0.0.0.0
WEBHOOK_SERVER_PORT=8080
WEBHOOK_FORWARD_TIMEOUT_MS=30000
# In Docker Desktop, host.docker.internal is usually correct. In this workspace,
# use the workspace container IP if Docker cannot reach host.docker.internal.
MASTRA_UPSTREAM_URL=http://host.docker.internal:4111

# Mastra Channels - Slack
# Webhook URL: https://your-domain.com/api/agents/supervisor-agent/channels/slack/webhook
ENABLE_SLACK_CHANNEL=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Optional: socket mode instead of public webhooks
SLACK_APP_TOKEN=
SLACK_SOCKET_FORWARDING_SECRET=
# Optional: OAuth/multi-workspace installs
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
# Optional: 32-byte base64 key for encrypting stored Slack installation tokens
SLACK_ENCRYPTION_KEY=

# Mastra Channels - Linear
# Webhook URL: https://your-domain.com/api/agents/supervisor-agent/channels/linear/webhook
LINEAR_WEBHOOK_SECRET=
LINEAR_BOT_USERNAME=
# Inbound mode: comments or agent-sessions. LINEAR_MODE is the adapter-native name;
# LINEAR_CHANNEL_MODE is also supported by this codebase and takes precedence.
LINEAR_CHANNEL_MODE=comments
LINEAR_MODE=comments
# Option A: personal API key
LINEAR_API_KEY=
# Option B: pre-obtained OAuth access token
LINEAR_ACCESS_TOKEN=
# Option C: multi-tenant OAuth app
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=
# Option D: single-tenant client credentials
LINEAR_CLIENT_CREDENTIALS_CLIENT_ID=
LINEAR_CLIENT_CREDENTIALS_CLIENT_SECRET=
LINEAR_CLIENT_CREDENTIALS_SCOPES=read,write,comments:create,issues:create

# Mastra Channels - GitHub
# Webhook URL: https://your-domain.com/api/agents/supervisor-agent/channels/github/webhook
ENABLE_GITHUB_CHANNEL=false
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_USERNAME=
# Option A: personal access token
GITHUB_TOKEN=
# Option B: GitHub App
GITHUB_APP_ID=
# Use a single-line PEM with escaped newlines, or configure the secret in your deploy platform.
GITHUB_PRIVATE_KEY=
# Optional for single-tenant GitHub App installs; omit for multi-tenant.
GITHUB_INSTALLATION_ID=

# Local Mastra Studio/API ports
# In Daytona-style proxied workspaces, Studio is exposed on 4111 and the API
# server listens internally on 4112.
MASTRA_STUDIO_PORT=4111
MASTRA_STUDIO_INTERNAL_PORT=4213
MASTRA_STUDIO_PROXY_PORT=4111
MASTRA_SERVER_PORT=4111
MASTRA_SERVER_HOST=0.0.0.0
MASTRA_SERVER_CORS_ORIGINS=

# Agent model overrides (defaults in shared.ts use minimax-coding-plan/MiniMax-M2.7)
MINIMAX_API_KEY=
MASTRA_AGENT_MODEL=
MASTRA_SUBAGENT_MODEL=
MASTRA_SUPERVISOR_MODEL=
MASTRA_CONTROL_MODEL=
MASTRA_OBSERVATIONAL_MEMORY_MODEL=

# Scorer model
MASTRA_EVAL_MODEL=

# Workspace
# auto uses the current sandbox when DAYTONA_SANDBOX_ID is present; set daytona to force a nested Daytona workspace sandbox.
MASTRA_WORKSPACE_SANDBOX=local
# Relative workspace-tool paths and Mastra storage resolve under this root.
MASTRA_WORKSPACE_ROOT=
# Comma-separated absolute roots exposed to workspace file tools. Defaults to / inside Daytona; use /home/daytona,/shared for a narrower view.
MASTRA_WORKSPACE_ACCESS_ROOTS=
# CWD for local/current-sandbox command execution. Defaults to the Mastra process cwd.
MASTRA_WORKSPACE_COMMAND_CWD=
MASTRA_DEFAULT_SNAPSHOT=daytona-agents/snapshot-coding-base:local

# Relays
PI_RELAY_URL=http://localhost:4000
PASEO_RELAY_URL=http://localhost:4001
