# Daytona Sandbox API
DAYTONA_API_KEY=
DAYTONA_API_SECRET=
MASTRA_DAYTONA_ENDPOINT=https://api.daytona.io

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/mastra

# Agent model overrides (defaults in shared.ts use minimax-coding-plan/MiniMax-M2.7)
MASTRA_AGENT_MODEL=
MASTRA_SUBAGENT_MODEL=
MASTRA_SUPERVISOR_MODEL=
MASTRA_CONTROL_MODEL=
MASTRA_OBSERVATIONAL_MEMORY_MODEL=

# Scorer model
MASTRA_EVAL_MODEL=

# Workspace
# auto uses the current sandbox when DAYTONA_SANDBOX_ID is present; set daytona to force a nested Daytona workspace sandbox.
MASTRA_WORKSPACE_SANDBOX=auto
# Relative workspace-tool paths and Mastra storage resolve under this root.
MASTRA_WORKSPACE_ROOT=
# Comma-separated absolute roots exposed to workspace file tools. Defaults to / inside Daytona; use /home/daytona,/shared for a narrower view.
MASTRA_WORKSPACE_ACCESS_ROOTS=
# CWD for local/current-sandbox command execution. Defaults to the Mastra process cwd.
MASTRA_WORKSPACE_COMMAND_CWD=
MASTRA_DEFAULT_SNAPSHOT=daytona-agents/snapshot-coding-base:local

# Relays
PI_RELAY_URL=http://localhost:4000
PASEO_RELAY_URL=http://localhost:4001

# Research tools
# Exa web search API key — get one at https://exa.ai. Required for research.exa-search.
EXA_API_KEY=
# GitHub personal access token — optional; improves rate limits for research.github-* tools.
# Public repos: 10 req/min unauthenticated → 30 req/min with GH_TOKEN.
# Recommended scopes: public_repo for public repos; repo for private repos.
GH_TOKEN=
